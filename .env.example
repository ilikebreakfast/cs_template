# =============================================================================
# Anthropic / Claude
# =============================================================================
# Your Anthropic API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# OpenAI
# =============================================================================
# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# PostgreSQL
# =============================================================================
# Full connection URL (used by SQLAlchemy, psycopg2, etc.)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://devuser:password@localhost:5432/devdb

# Individual PostgreSQL credentials (used by docker-compose.yml)
POSTGRES_USER=devuser
POSTGRES_PASSWORD=password
POSTGRES_DB=devdb

# =============================================================================
# ODBC / SQL Server / Oracle
# =============================================================================
# Example for SQL Server:
# ODBC_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=myserver.database.windows.net;DATABASE=mydb;UID=myuser;PWD=mypassword;Encrypt=yes;TrustServerCertificate=no
# Example for Oracle:
# ODBC_CONNECTION_STRING=DRIVER={Oracle 19c ODBC driver};DBQ=hostname:1521/service_name;UID=myuser;PWD=mypassword
ODBC_CONNECTION_STRING=

# =============================================================================
# Redis
# =============================================================================
# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Browser automation
# =============================================================================
# Remote Selenium Grid URL (leave empty to use local ChromeDriver)
SELENIUM_REMOTE_URL=

# =============================================================================
# Application
# =============================================================================
# A random secret key for signing sessions / JWTs
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-key

# Application environment: development | staging | production
ENVIRONMENT=development
